# ─── Server Configuration ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ─── Database Configuration ───────────────────────────────────────────────────
# Replace with your actual Supabase PostgreSQL connection string
DATABASE_URL=

# ─── Authentication (JWT) ─────────────────────────────────────────────────────
# Minimum 32 characters long random string
JWT_SECRET=
JWT_EXPIRES_IN=24h

# ─── Redis / BullMQ ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Backend-2 Integration ────────────────────────────────────────────────────
BACKEND2_URL=http://localhost:5001
# Shared secret for authenticating communication between Backend-1 and Backend-2
INTERNAL_API_KEY=

# ─── Database Seeding Defaults ────────────────────────────────────────────────
SEED_ADMIN_EMAIL=superadmin@recruitai.com
SEED_ADMIN_PASSWORD=Admin@123

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_SES_FROM_EMAIL=no-reply@yourdomain.com
