# ─── Server Configuration ─────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5001

# ─── Integration ──────────────────────────────────────────────────────────────
# URL of Backend-1
BACKEND1_URL=http://localhost:5000
# Shared secret for authenticating communication (MUST match Backend-1's INTERNAL_API_KEY)
INTERNAL_API_KEY=

# ─── Redis / BullMQ ───────────────────────────────────────────────────────────
# Shared Redis instance with Backend-1
REDIS_URL=redis://localhost:6379

# ─── AI / Gemini API ──────────────────────────────────────────────────────────
# Required when actual Gemini/AI parsing is implemented
GEMINI_API_KEY=
